{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },

    "module": "esnext",
    "moduleResolution": "bundler",
    "checkJs": true,
    "strict": false,
    "noUnusedLocals": false,
    "jsx": "react-jsx",
    "allowImportingTsExtensions": false
  },
  "include": ["src"]
}


